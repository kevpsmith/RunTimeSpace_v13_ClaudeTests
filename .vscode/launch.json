{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/this_studio", // Set working directory to 'this_studio'
            "env": {
                "PYTHONPATH": "${workspaceFolder}/this_studio" // Optional: add this_studio to PYTHONPATH
            }
        },
        {
            "name": "Backtest: Smoke Test (Jan 2025)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backtest/Backtest_Smoke_Test.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Backtest: Full Run (Weekly)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backtest/Backtest_Runner.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Backtest: Full Run (Daily)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backtest/Backtest_Runner.py",
            "args": ["--daily"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}